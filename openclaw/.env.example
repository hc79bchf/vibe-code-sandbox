# Sandbox identity — used for container name, network, and display title
SANDBOX_NAME=openclaw

# Path to the project repo on your host machine.
# This directory is mounted as /workspace inside the container.
#
# Examples:
#   PROJECT_PATH=~/projects/openclaw
#   PROJECT_PATH=/Users/you/code/openclaw

PROJECT_PATH=~/projects/openclaw

# Claude UI Dashboard port (auto-detected if not set; increments to avoid collisions)
# DASHBOARD_PORT=8080

# Vibecraft server port (must match across all sandboxes)
VIBECRAFT_PORT=4003

# Remote Control: continue sandbox sessions from phone/tablet/browser via claude.ai/code
# Requires Pro/Max plan and /login authentication inside the container
# ENABLE_REMOTE_CONTROL=true

# OpenClaw API keys
GOOGLE_AI_API_KEY=
ANTHROPIC_API_KEY=
TELEGRAM_BOT_TOKEN=
# Generate with: openssl rand -hex 32
GATEWAY_AUTH_TOKEN=
